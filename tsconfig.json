{
    "compilerOptions": {
        "target": "ES2017",
        "module": "none",
        "lib": ["DOM", "ES2017"],
        "sourceMap": false,
        "removeComments": true,
        "noEmitOnError": true,
        "strict": true,
        "alwaysStrict": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitAny": true,
        "noImplicitThis": true,
        "noImplicitReturns": true
    },
    "files": ["scripts.ts"]
}
